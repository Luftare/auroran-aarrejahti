# Kopioi tiedosto nimelle .env ja täytä arvot. Älä koskaan lisää .env-tiedostoa gitiin.

# Julkinen osoite (ilman https://-alkua)
DOMAIN=aarre.example.fi

# Sovelluskontin kuva (GHCR tai paikallisesti rakennettu)
APP_IMAGE=ghcr.io/OWNER/auroran-aarrejahti:latest

# Tietokannan salasana (keksi pitkä ja satunnainen, esim. `openssl rand -base64 24`)
POSTGRES_PASSWORD=

# Ylläpitäjän ensikäynnistys — tunnus luodaan, jos sitä ei ole
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Ylläpito

# Sähköposti (Brevo tai muu EU-pohjainen SMTP). Ilman näitä vahvistus-
# ja palautuslinkit tulostuvat sovelluksen lokiin.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Auroran aarrejahti <aurora@aarre.example.fi>
